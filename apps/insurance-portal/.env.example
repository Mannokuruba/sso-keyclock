# Auth0 Configuration — Copy this to .env.local and fill in your values
# Get these from: Auth0 Dashboard > Applications > Your App > Settings

VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here
VITE_AUTH0_AUDIENCE=https://insurance-api.yourdomain.com
VITE_AUTH0_REDIRECT_URI=http://localhost:3010/callback
VITE_AUTH0_LOGOUT_URI=http://localhost:3010

# App Settings
VITE_APP_NAME=InsureConnect
VITE_APP_ENV=development
