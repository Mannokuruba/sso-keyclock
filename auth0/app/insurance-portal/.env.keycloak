# Keycloak SSO — InsureConnect Environment Variables
# Copy this to .env.local and fill in your Keycloak server details

# Keycloak server base URL (no trailing slash)
# Local dev:    http://localhost:8080
# Production:   https://sso.yourcompany.com
VITE_KEYCLOAK_URL=http://localhost:8080

# Realm name you created in Keycloak Admin Console
VITE_KEYCLOAK_REALM=insurance

# Client ID of the SPA client you created in Keycloak (must be "public" access type)
VITE_KEYCLOAK_CLIENT_ID=insurance-portal
